# ==================================================
# App
# ==================================================
APP_ENV=production
APP_PORT=8080

# ==================================================
# Database
# EC2内PostgreSQLコンテナ想定
# docker-compose上のpostgresサービス名に合わせる
# ==================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=timexeed
DB_PASSWORD=change_me
DB_NAME=timexeed_db
DB_SSLMODE=disable

# ==================================================
# JWT
# 本番では長くて推測されにくい値にする
# ==================================================
JWT_SECRET=change_me

# ==================================================
# Google OAuth / Drive
# OAuthクライアント情報
# ==================================================
GOOGLE_OAUTH_CLIENT_ID=change_me
GOOGLE_OAUTH_CLIENT_SECRET=change_me
GOOGLE_OAUTH_REFRESH_TOKEN=change_me

# ==================================================
# Google Service Account
# Dockerコンテナ内で見えるパス
# docker-composeで secrets/google-service-account.json をここへマウントする
# ==================================================
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-service-account.json

# ==================================================
# Google Drive folder / link settings
# ==================================================
GOOGLE_DRIVE_EXPENSE_RECEIPT_LINK_TYPE=EXPENSE_RECEIPT_BOX
GOOGLE_DRIVE_PERSONAL_INFORMATION_ROOT_FOLDER_ID=change_me
GOOGLE_DRIVE_EXPENSE_ROOT_FOLDER_ID=change_me

# ==================================================
# CORS
# 本番フロントURL
# 例: https://example.com
# ==================================================
FRONTEND_ORIGIN=https://example.com